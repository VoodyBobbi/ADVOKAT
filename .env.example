# ===================================================================
#               Минимальный файл конфигурации (.env)
# ===================================================================
# Скопируйте этот файл в .env и заполните значения.
# Все остальные настройки (пути, модели для поиска и т.д.)
# уже заданы по умолчанию в коде.

# ОБЯЗАТЕЛЬНО: Вставьте сюда токен, который вы получили от @BotFather.
TELEGRAM_BOT_TOKEN=вставь_свой_токен_сюда

# ОСНОВНАЯ МОДЕЛЬ: Убедитесь, что эта модель есть в вашем `ollama list`.
# Рекомендуется: qwen2.5:7b
MODEL_NAME=qwen2.5:7b

# АДРЕС OLLAMA: Менять, только если Ollama у вас работает на другой машине.
OLLAMA_URL=http://localhost:11434
