# Скопируй этот файл в .env и заполни своими значениями

# Токен от @BotFather в Telegram
TELEGRAM_BOT_TOKEN=вставь_токен_сюда

# Название модели Ollama для генерации ответов
MODEL_NAME=gemma3:4b

# Адрес Ollama (обычно не нужно менять)
OLLAMA_URL=http://localhost:11434

# Модель для эмбеддингов (поиск по базе законов)
EMBEDDING_MODEL=nomic-embed-text

# Пути к файлам (можно не трогать)
DB_PATH=logs.db
CACHE_DB_PATH=cache.db
CHROMA_PATH=./chroma_db
DOCS_PATH=docs

# Настройки кеша и памяти (можно не трогать)
CACHE_TTL_SECONDS=604800
MAX_MEMORY_MESSAGES=20
MEMORY_RESTORE_LIMIT=10
SEARCH_TOP_K=5
SEARCH_DISTANCE_THRESHOLD=1.5
